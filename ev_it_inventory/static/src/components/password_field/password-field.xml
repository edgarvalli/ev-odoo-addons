<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ev_it_inventory.PasswordField">
        <div class="input-group">
            <input
                class="o_input o_field_placeholder"
                t-att-type="state.visible ? 'text' : 'password'"
                t-att-value="state.value || ''"
                t-on-input="onInput"
            />
            <div class="o_field_input_buttons">
                <button type="button"
                        class="btn"
                        t-on-click="toggle">
                    <i t-att-class="state.visible ? 'fa fa-eye-slash' : 'fa fa-eye'"/>
                </button>
            </div>
        </div>
    </t>
</templates>