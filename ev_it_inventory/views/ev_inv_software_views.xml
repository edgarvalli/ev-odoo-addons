<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         LIST VIEW
    ========================== -->
    <record id="view_ev_inv_software_list" model="ir.ui.view">
        <field name="name">ev.inv.software.list</field>
        <field name="model">ev.inv.software</field>
        <field name="arch" type="xml">
            <list string="Software">
                <field name="name" />
                <field name="version" />
                <field name="vendor_id" />
                <field name="company_id" />
                <field name="used_seats" />
                <field name="seats" />
                <field name="cost" />
            </list>
        </field>
    </record>

    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="view_ev_inv_software_form" model="ir.ui.view">
        <field name="name">ev.inv.software.form</field>
        <field name="model">ev.inv.software</field>
        <field name="arch" type="xml">
            <form string="Software">
                <sheet>
                    <div class="o_employee_avatar ms-2 p-0">
                        <field
                            name="image_1920"
                            widget="image"
                            class="oe_avatar"
                            options="{'preview_image': 'image_128'}"
                        />
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                        <h2>
                            <field name="version" />
                        </h2>
                    </div>

                    <group>
                        <group string="Información General">
                            <field name="vendor_id" />
                            <field name="supplier_id" />
                            <field name="invoice_number" />
                        </group>

                        <group string="Asignación">
                            <field name="company_id" />
                        </group>
                    </group>

                    <group string="Licenciamiento">
                        <group>
                            <field name="seats" />
                            <field name="used_seats" />
                        </group>
                    </group>

                    <group string="Finanzas">
                        <group>
                            <field name="cost" />
                            <field name="currency_id" />
                        </group>
                    </group>

                    <notebook>

                        <page string="Licencias" invisible="not id">
                            <field name="license_ids">
                                <list string="Licencias" default_order="expiration_date asc"
                                    delete="1">
                                    <field name="name" />
                                    <field name="license_key" />
                                    <field name="device_id" />
                                    <field name="user_id" />
                                    <field name="expiration_date" />
                                    <field
                                        name="days_to_expire"
                                        decoration-success="days_to_expire &gt; renewal_reminder_days"
                                        decoration-warning="days_to_expire &lt; renewal_reminder_days and days_to_expire &gt; 10"
                                        decoration-danger="days_to_expire &lt; 10"
                                        readonly="1"
                                    />
                                </list>

                                <form string="Licencia">
                                    <sheet>
                                        <div class="ot_title">
                                            <h1>
                                                <field name="name" />
                                            </h1>
                                        </div>

                                        <group>
                                            <group string="Licencia">
                                                <field name="license_key" />
                                                <field name="license_type" />
                                            </group>
                                            <group string="Asignación">
                                                <field name="user_id" />
                                                <field name="device_id" />
                                            </group>
                                        </group>
                                        <group string="Vencimiento">
                                            <field name="expiration_date" />
                                            <field name="renewal_reminder_days" />
                                        </group>

                                        <separator string="Observaciones" />
                                        <field name="notes" nolabel="1" />
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Observaciones">
                            <field name="notes" nolabel="1" />
                        </page>

                    </notebook>
                </sheet>
                <chatter reload_on_follower="True" />
            </form>
        </field>
    </record>

    <!-- =========================
         KANBAN VIEW
    ========================== -->
    <record id="view_ev_inv_software_kanban" model="ir.ui.view">
        <field name="name">ev.inv.software.kanban</field>
        <field name="model">ev.inv.software</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name" />
                <field name="version" />
                <field name="image_128" />
                <field name="image_1024" />

                <templates>
                    <t t-name="card">
                        <aside class="o_kanban_aside_full">
                            <t t-if="record.image_1024.raw_value">
                                <field name="image_1024" widget="background_image"
                                    options="{'zoom': true, 'zoom_delay': 1000, 'preview_image':'image_128'}"
                                    class="d-block position-relative" />
                            </t>
                            <t t-elif="record.image_128.raw_value">
                                <field name="image_128" widget="background_image"
                                    options="{'zoom': true, 'zoom_delay': 1000}"
                                    class="d-block position-relative" />
                            </t>
                            <div t-else=""
                                class="d-flex align-items-center justify-content-center bg-100 bg-gradient">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-75 h-75 opacity-50"
                                    viewBox="0 0 20 20">
                                    <g fill="currentColor">
                                        <path
                                            d="M 10 11 C 4.08 11 2 14 2 16 L 2 19 L 18 19 L 18 16 C 18 14 15.92 11 10 11 Z" />
                                        <circle cx="10" cy="5.5" r="4.5" />
                                    </g>
                                </svg>
                            </div>
                        </aside>
                        <div class="oe_kanban_card p-3">

                            <div class="fw-bold fs-5">
                                <i class="fa-solid fa-person"></i>
                                <field name="name" />
                            </div>

                            <div>
                                <strong>Versión:</strong>
                                <field name="version" />
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- =========================
         SEARCH / DASHBOARD FILTERS
    ========================== -->
    <record id="view_ev_inv_software_view_search" model="ir.ui.view">
        <field name="name">ev.inv.software.search</field>
        <field name="model">ev.inv.software</field>
        <field name="arch" type="xml">
            <search string="Buscar Software">
                <field name="name" />
            </search>
        </field>
    </record>

</odoo>