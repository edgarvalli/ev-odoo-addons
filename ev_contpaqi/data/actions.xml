<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_department_action_server" model="ir.actions.server">
        <field name="name">Sync Departamentos Nominas</field>
        <field name="model_id" ref="hr.model_hr_department" />
        <field name="binding_model_id" ref="hr.model_hr_department" />
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">
            action = model.action_sync_contpaqi()
        </field>
    </record>

    <record id="hr_employee_action_server" model="ir.actions.server">
        <field name="name">Sync Empleados Contpaqi</field>
        <field name="model_id" ref="hr.model_hr_employee" />
        <field name="binding_model_id" ref="hr.model_hr_employee" />
        <field name="state">code</field>
        <field name="code">
            action = model.action_sync_employee()
        </field>
    </record>

</odoo>