<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ev_res_company_nominas_form" model="ir.ui.view">
        <field name="name">ev.res.company.nominas_form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']" position="inside">
                <group name="ev_contpaqi_nominas" string="Configuracion Contpaqi">
                    <group>
                        <field name="ev_contpaqi_nominas_db" />
                    </group>
                    <group>
                        <field name="ev_contpaqi_comercial_db" />
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>